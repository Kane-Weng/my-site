{
    "name": "Jekyll on Ubuntu",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "forwardPorts": [4000],
    "customizations": {
        "vscode": {
            "extensions": [
                "rebornix.Ruby",
                "castwide.solargraph",
                "jekyll.jekyll-syntax-highlighting"
            ]
        }
    },
    "postCreateCommand": "bundle install",
    "remoteUser": "root"
}